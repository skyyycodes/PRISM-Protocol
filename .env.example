# Anchor / Solana
ANCHOR_PROVIDER_URL=https://api.devnet.solana.com
ANCHOR_WALLET=keys/admin.json

# Helius RPC
HELIUS_API_KEY=your_helius_key_here
NEXT_PUBLIC_RPC_URL=https://devnet.helius-rpc.com/?api-key=your_helius_key_here

# Program IDs
NEXT_PUBLIC_PRISM_CORE_PROGRAM_ID=
NEXT_PUBLIC_PRISM_AMM_PROGRAM_ID=

# Demo state
NEXT_PUBLIC_VAULT_ID=0

# USDC mint (Circle's official devnet USDC)
NEXT_PUBLIC_USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU

# IKA / collateral demo
NEXT_PUBLIC_IKA_ORACLE_URL=http://localhost:3000/api/ika-test-oracle
NEXT_PUBLIC_IKA_FULLNODE_URL=https://sui-testnet-rpc.publicnode.com
NEXT_PUBLIC_IKA_FALLBACK_RPC_URL=https://fullnode.testnet.sui.io:443
NEXT_PUBLIC_IKA_NETWORK=testnet

# Switchboard
SWITCHBOARD_AGGREGATOR_PUBKEY=

# Dodo Payments (fiat loan repayment — Superteam India track)
# Set MOCK_DODO=true to bypass real API (uses local simulator at /dodo-mock-pay)
DODO_API_KEY=
DODO_API_BASE=https://test.dodopayments.com
DODO_WEBHOOK_SECRET=
MOCK_DODO=true
# Product ID of a variable-price "Loan Repayment" product created in the Dodo dashboard
DODO_REPAYMENT_PRODUCT_ID=
# Admin keypair (base64, 64 bytes) — used server-side to bridge fiat -> USDC via SPL transfer
ADMIN_SECRET_KEY_B64=
# Public app URL (set to cloudflared tunnel URL during demo)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Dune SIM (event analytics)
DUNE_SIM_API_KEY=your_dune_sim_key_here

# Cloak SDK
CLOAK_API_ENDPOINT=https://api.cloak.dev

# Bags.fm (Bags hackathon — creator-credit + fee-stream collateral)
# Server-only for keeper / launch scripts. Without this key, app/lib/bags.ts
# returns deterministic mock data so the UI still renders.
BAGS_API_KEY=
# Optional public mirror for client-side widgets (use only for read-only flows).
NEXT_PUBLIC_BAGS_API_KEY=
NEXT_PUBLIC_BAGS_API_BASE_URL=https://api.bags.fm
# Set once the protocol's $PRISM token is launched on Bags.
NEXT_PUBLIC_BAGS_PROTOCOL_TOKEN_MINT=
NEXT_PUBLIC_BAGS_TOKEN_URL=https://bags.fm
# Ed25519 pubkey of the Bags attestation oracle. Replace with the real oracle
# key on devnet/mainnet. The default below is deterministic for the local
# mock at /api/bags-oracle (see docs/bags-hackathon-strategy.md).
NEXT_PUBLIC_BAGS_ORACLE_PUBKEY=6yzGfeqaT58TQjyTNJunc4uULP1qq6X5tNHobcGsCYxR
# Wallets used by scripts/launch-bags-token.ts (only required for --commit)
BAGS_LAUNCH_WALLET=keys/bags_launch.json
BAGS_TEAM_WALLET=
BAGS_TREASURY_WALLET=
PRISM_TOKEN_NAME=PRISM Protocol
PRISM_TOKEN_SYMBOL=PRISM
PRISM_TOKEN_IMAGE=https://prismprotocol.dev/og.png
PRISM_TOKEN_TWITTER=
# Keeper targets — CSV of feeClaimerPda:tokenMint:loanPubkey triples
BAGS_KEEPER_TARGETS=

# Database
DATABASE_URL="postgres://user:password@host:5432/prism?sslmode=require"
