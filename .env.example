# Anchor / Solana
ANCHOR_PROVIDER_URL=https://api.devnet.solana.com
ANCHOR_WALLET=keys/admin.json

# Helius RPC
HELIUS_API_KEY=your_helius_key_here
NEXT_PUBLIC_RPC_URL=https://devnet.helius-rpc.com/?api-key=your_helius_key_here

# Program IDs
NEXT_PUBLIC_PRISM_CORE_PROGRAM_ID=
NEXT_PUBLIC_PRISM_AMM_PROGRAM_ID=

# Demo state
NEXT_PUBLIC_VAULT_ID=0

# USDC mint (Circle's official devnet USDC)
NEXT_PUBLIC_USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU

# IKA / collateral demo
NEXT_PUBLIC_IKA_ORACLE_URL=http://localhost:3000/api/ika-test-oracle
NEXT_PUBLIC_IKA_FULLNODE_URL=https://sui-testnet-rpc.publicnode.com
NEXT_PUBLIC_IKA_FALLBACK_RPC_URL=https://fullnode.testnet.sui.io:443
NEXT_PUBLIC_IKA_NETWORK=testnet

# Switchboard
SWITCHBOARD_AGGREGATOR_PUBKEY=

# Dodo Payments (fiat loan repayment — Superteam India track)
# Set MOCK_DODO=true to bypass real API (uses local simulator at /dodo-mock-pay)
DODO_API_KEY=
DODO_API_BASE=https://test.dodopayments.com
DODO_WEBHOOK_SECRET=
MOCK_DODO=true
# Product ID of a variable-price "Loan Repayment" product created in the Dodo dashboard
DODO_REPAYMENT_PRODUCT_ID=
# Admin keypair (base64, 64 bytes) — used server-side to bridge fiat -> USDC via SPL transfer
ADMIN_SECRET_KEY_B64=
# Public app URL (set to cloudflared tunnel URL during demo)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Dune SIM (event analytics)
DUNE_SIM_API_KEY=your_dune_sim_key_here

# Cloak SDK
CLOAK_API_ENDPOINT=https://api.cloak.dev

# Database
DATABASE_URL="postgres://user:password@host:5432/prism?sslmode=require"
