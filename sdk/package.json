{
  "name": "prismprotocol-sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for the PRISM Protocol credit engine and AMM on Solana.",
  "private": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/skyyycodes/PRISM-Protocol.git",
    "directory": "sdk"
  },
  "homepage": "https://github.com/skyyycodes/PRISM-Protocol#readme",
  "keywords": [
    "solana",
    "anchor",
    "defi",
    "credit",
    "tranches",
    "amm",
    "prism-protocol"
  ],
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./idl": {
      "types": "./dist/idl.d.ts",
      "import": "./dist/idl.js",
      "require": "./dist/idl.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4"
  },
  "devDependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "@types/node": "^22",
    "tsup": "^8.3.5",
    "typescript": "^5"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  }
}
